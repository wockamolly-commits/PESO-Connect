# Environment Variables for PESO Connect
# Copy this file to .env and fill in your Firebase credentials

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Email Notifications (EmailJS)
# Sign up at https://www.emailjs.com/ to get these credentials
# Create email templates in EmailJS dashboard with these IDs:
# - template_jobseeker_registration
# - template_jobseeker_verified
# - template_jobseeker_rejected
# - template_employer_registration
# - template_employer_approved
# - template_employer_rejected
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAIL_NOTIFICATIONS_ENABLED=false

# Admin Account Seeding
# Used by the admin login page to create the initial admin account
VITE_ADMIN_EMAIL=admin@peso.gov.ph
VITE_ADMIN_PASSWORD=your_secure_password_here
