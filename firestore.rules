rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is the document owner
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Helper function to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to check if user is verified
    function isVerified() {
      return getUserData().is_verified == true;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return getUserData().role == 'admin';
    }
    
    // Helper function to check if user is employer
    function isEmployer() {
      return getUserData().role == 'employer';
    }
    
    // Helper function to check if user is jobseeker
    function isJobseeker() {
      return getUserData().role == 'jobseeker';
    }
    
    // Users collection
    match /users/{userId} {
      // Anyone can read user profiles
      allow read: if isAuthenticated();
      
      // Users can create their own profile
      // employer_status must be 'pending' on create (if present), is_verified must be false
      allow create: if isAuthenticated() && isOwner(userId) && 
                       request.resource.data.is_verified == false &&
                       (!('employer_status' in request.resource.data) || 
                        request.resource.data.employer_status == 'pending');
      
      // Users can update their own profile except is_verified and employer_status
      allow update: if isAuthenticated() && isOwner(userId) && 
                       request.resource.data.is_verified == resource.data.is_verified &&
                       (!('employer_status' in resource.data) || 
                        request.resource.data.employer_status == resource.data.employer_status);
      
      // Only admin can modify is_verified and employer_status
      allow update: if isAuthenticated() && isAdmin();
      
      // No one can delete user profiles except admin
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // Job postings collection
    match /job_postings/{jobId} {
      // Anyone can read open job postings (public access for job listings)
      allow read: if true;
      
      // Only verified employers can create job postings
      allow create: if isAuthenticated() && isEmployer() && isVerified() &&
                       request.resource.data.employer_id == request.auth.uid;
      
      // Employers can update their own job postings
      allow update: if isAuthenticated() && 
                       (isOwner(resource.data.employer_id) || isAdmin());
      
      // Employers can delete their own job postings or admin
      allow delete: if isAuthenticated() && 
                       (isOwner(resource.data.employer_id) || isAdmin());
    }
    
    // Admins collection (for tracking seeded admin)
    match /admins/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Applications collection
    match /applications/{applicationId} {
      // Applicants can read their own applications
      // Employers can read applications for their jobs
      // Admin can read all
      allow read: if isAuthenticated() && 
                     (isOwner(resource.data.user_id) || isAdmin() ||
                      exists(/databases/$(database)/documents/job_postings/$(resource.data.job_id)) &&
                      get(/databases/$(database)/documents/job_postings/$(resource.data.job_id)).data.employer_id == request.auth.uid);
      
      // Only verified jobseekers can create applications
      allow create: if isAuthenticated() && isJobseeker() && isVerified() &&
                       request.resource.data.user_id == request.auth.uid &&
                       request.resource.data.status == 'pending';
      
      // Employers can update application status for their jobs
      allow update: if isAuthenticated() && 
                       (isAdmin() ||
                        (exists(/databases/$(database)/documents/job_postings/$(resource.data.job_id)) &&
                         get(/databases/$(database)/documents/job_postings/$(resource.data.job_id)).data.employer_id == request.auth.uid));
      
      // Only admin can delete applications
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // Conversations collection (messaging)
    match /conversations/{conversationId} {
      // Only participants and admins can read
      allow read: if isAuthenticated() &&
                     (request.auth.uid in resource.data.participants || isAdmin());

      // Verified users can create conversations they are a participant of
      allow create: if isAuthenticated() && isVerified() &&
                       request.auth.uid in request.resource.data.participants &&
                       request.resource.data.participants.size() == 2;

      // Participants can update (lastMessage, unreadCount)
      allow update: if isAuthenticated() &&
                       request.auth.uid in resource.data.participants;

      // Only admin can delete conversations
      allow delete: if isAuthenticated() && isAdmin();

      // Messages subcollection
      match /messages/{messageId} {
        // Participants of parent conversation and admins can read
        allow read: if isAuthenticated() &&
                       (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants || isAdmin());

        // Participants can create messages, senderId must match auth uid
        allow create: if isAuthenticated() && isVerified() &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
                         request.resource.data.senderId == request.auth.uid;

        // Participants can update (for readBy)
        allow update: if isAuthenticated() &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // Notifications collection
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isAuthenticated() && isOwner(resource.data.user_id);
      
      // System or admin can create notifications
      allow create: if isAuthenticated() && isAdmin();
      
      // Users can update their own notifications (mark as read)
      allow update: if isAuthenticated() && isOwner(resource.data.user_id);
      
      // Users can delete their own notifications
      allow delete: if isAuthenticated() && isOwner(resource.data.user_id);
    }
  }
}
